{
  "name": "avd-mcp",
  "version": "0.2.0",
  "type": "module",
  "description": "MCP server for Android Virtual Device automation",
  "author": "avd-mcp contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jramalho/avd-mcp.git"
  },
  "homepage": "https://github.com/jramalho/avd-mcp#readme",
  "bugs": {
    "url": "https://github.com/jramalho/avd-mcp/issues"
  },
  "bin": {
    "avd-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test:unit": "pnpm build && node --test dist/tests/unit/*.test.js",
    "test:mcp": "pnpm build && node dist/tests/mcp-smoke-test.js",
    "test:adb-tools": "pnpm build && node dist/tests/mcp-adb-tools-scenarios.js",
    "test:media-tools": "pnpm build && node dist/tests/mcp-media-scenarios.js",
    "test:network-device-tools": "pnpm build && node dist/tests/mcp-network-device-scenarios.js",
    "test": "pnpm test:mcp",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "sharp": "^0.34.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
